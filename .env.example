# Book of Findings — required environment variables.
#
# Local dev:  copy this file to `.env.local` and fill in real values.
# Deployed:   set these as environment variables on your host
#             (Vercel/Azure settings, Docker -e, pm2/systemd env, etc.),
#             then redeploy/restart.
#
# Both are REQUIRED in production: the app refuses to issue a session without a
# valid SESSION_SECRET, so login will fail until these are set.

# Shared login password (server-side only — never sent to the browser).
APP_PASSWORD=change-me

# Secret used to sign session cookies. Must be at least 32 characters.
# Generate one with:  openssl rand -hex 32
# Rotating this value immediately invalidates all existing sessions.
SESSION_SECRET=replace-with-a-32-plus-character-random-string
